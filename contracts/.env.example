# RPC URLs
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Robinhood Chain (chainId 4663) — used by `--rpc-url robinhood`
ROBINHOOD_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan V2 API key (works for Base and 60+ EVM chains)
BASESCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Deployer private key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Tenderly Virtual TestNet (forked from Sepolia, chain_id: 73571)
TENDERLY_VIRTUAL_TESTNET_RPC=https://virtual.sepolia.eu.rpc.tenderly.co/YOUR_VNET_ID
TENDERLY_ACCESS_KEY=YOUR_TENDERLY_ACCESS_KEY

# Optional: Initial ETH reserve for deployment (default: 0.069 ETH)
# Must be >= MIN_LIQUIDITY (0.01 ETH)
INITIAL_ETH_RESERVE=100000000000000000
