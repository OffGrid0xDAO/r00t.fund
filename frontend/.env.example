# ============================================
# r00t.fund Configuration
# ============================================
# Copy this to .env and update values for your deployment

# Network (42161 = Arbitrum One, 421614 = Arbitrum Sepolia)
VITE_CHAIN_ID=42161
VITE_RPC_URL=https://arbitrum-one.publicnode.com

# Ponder Indexer (for trades, stats, merkle tree data)
VITE_INDEXER_URL=http://localhost:42069

# ============================================
# Contract Addresses - UPDATE AFTER DEPLOYMENT
# ============================================

# Main ZkAMM contract (handles swaps + privacy pool)
VITE_ZKAMM_ADDRESS=0x...

# ROOT token ERC20 address (if separate)
VITE_ROOT_TOKEN_ADDRESS=0x...

# TokenPool for merkle tree commitments
VITE_TOKEN_POOL_ADDRESS=0x...

# Launchpad for launching new privacy tokens
VITE_LAUNCHPAD_ADDRESS=0x...

# Hidden pool for private governance
VITE_HIDDEN_POOL_ADDRESS=0x...

# ============================================
# Token Settings (optional)
# ============================================
VITE_TOKEN_NAME=r00t
VITE_TOKEN_SYMBOL=ROOT

# ============================================
# Optional Services
# ============================================

# Relayer URL (for gasless transactions)
VITE_RELAYER_URL=

# WalletConnect Project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
