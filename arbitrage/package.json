{
  "name": "@r00t-fund/arbitrage",
  "version": "1.0.0",
  "description": "Market making and arbitrage bot for r00t.fund dark pool and Uniswap V4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/bot.ts",
    "start:prod": "node dist/bot.js",
    "dev": "ts-node-dev --respawn src/bot.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arbitrage",
    "defi",
    "market-making",
    "uniswap",
    "zk",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "viem": "^2.21.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
