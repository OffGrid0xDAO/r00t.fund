# Arbitrage Bot Configuration

# Required: Private key for executing trades (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Required: RPC URL
RPC_URL=https://mainnet.base.org

# Pool Addresses
DARK_POOL_ADDRESS=0x...
UNISWAP_POOL_ADDRESS=0x...

# Trading Parameters
MIN_SPREAD_BPS=50          # Minimum spread to trade (0.5%)
MAX_POSITION_SIZE=100000   # Max tokens per trade
MAX_SLIPPAGE_BPS=100       # Max slippage tolerance (1%)

# Gas Settings
MAX_GAS_PRICE=0.00005      # Max gas price in ETH (50 gwei)
GAS_BUFFER=1.2             # Gas estimate multiplier

# Risk Limits
MAX_DAILY_LOSS=1           # Max daily loss in ETH
MAX_OPEN_POSITIONS=3       # Max concurrent trades
COOLDOWN_MS=5000           # Cooldown between trades (ms)

# Execution Mode
DRY_RUN=true               # Set to false for live trading
